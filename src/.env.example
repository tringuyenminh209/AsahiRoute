APP_NAME="朝日ルート"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
APP_URL=http://localhost:2009

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=asahi_route
DB_USERNAME=asahi_user
DB_PASSWORD=

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=pusher
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=asahi

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@yourdomain.jp"
MAIL_FROM_NAME="${APP_NAME}"

# ── AWS S3 (Phase 5 — photo upload) ──────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-northeast-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ── Pusher / Soketi (WebSocket) ───────────────────────────────────────────────
# Dev:  PUSHER_HOST=soketi, PUSHER_SCHEME=http,  PUSHER_PORT=6001
# Prod: PUSHER_HOST=ws.yourdomain.jp, PUSHER_SCHEME=https, PUSHER_PORT=443
PUSHER_APP_ID=asahi-app
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dev:  FRONTEND_URL=http://localhost:5173
# Prod: FRONTEND_URL=https://app.yourdomain.jp
# Multiple origins (comma-separated): https://app.jp,https://www.app.jp
FRONTEND_URL=http://localhost:5173

# ── Python Optimizer ─────────────────────────────────────────────────────────
OPTIMIZER_URL=http://optimizer:8000

# ── Vite (Frontend build — copy to frontend/.env) ────────────────────────────
VITE_API_URL=/api/v1
VITE_PUSHER_APP_KEY=
VITE_PUSHER_HOST=localhost
VITE_PUSHER_PORT=6001
VITE_PUSHER_SCHEME=http
VITE_PUSHER_APP_CLUSTER=mt1
