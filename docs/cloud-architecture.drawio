    <diagram id="notes-page2" name="設計メモ・スケール">
        <mxGraphModel dx="870" dy="410" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1654" pageHeight="1169" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="n100" value="AsahiRoute — 設計メモ・スケーリング方針" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#232F3E;" parent="1" vertex="1">
                    <mxGeometry x="200" y="15" width="1200" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="n200" value="サービス構成" style="rounded=1;whiteSpace=wrap;fillColor=#FFF8EE;strokeColor=#D6B656;fontSize=13;fontStyle=1;fontColor=#6B4400;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="65" width="480" height="480" as="geometry"/>
                </mxCell>
                <mxCell id="n201" value="&lt;b&gt;asahi-api&lt;/b&gt; (ECS Fargate)&#10;• PHP 8.3-FPM + Nginx 1.25&#10;• Laravel 11 + Sanctum 認証&#10;• vCPU: 0.5 → 2 (Auto Scale)&#10;• Memory: 1GB → 4GB&#10;• Port: 80 (HTTP)&#10;&#10;&lt;b&gt;asahi-soketi&lt;/b&gt; (ECS Fargate)&#10;• Soketi (Pusher-compatible WS)&#10;• private-shop.{shopId} チャンネル&#10;• vCPU: 0.25, Memory: 512MB&#10;• Port: 6001 (WS), 9601 (metrics)&#10;&#10;&lt;b&gt;asahi-optimizer&lt;/b&gt; (ECS Fargate)&#10;• Python 3.12 + FastAPI + OR-Tools&#10;• TSP route optimization&#10;• vCPU: 1 (CPU-intensive), Mem: 2GB&#10;• Port: 8000 (HTTP internal)&#10;&#10;&lt;b&gt;asahi-worker&lt;/b&gt; (ECS Fargate)&#10;• Laravel Queue Worker (Redis)&#10;• OptimizeRouteJob / Notifications&#10;• vCPU: 0.25, Memory: 512MB" style="text;html=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="55" y="90" width="450" height="440" as="geometry"/>
                </mxCell>
                <mxCell id="n300" value="データ層" style="rounded=1;whiteSpace=wrap;fillColor=#E0EAF5;strokeColor=#2E73B8;fontSize=13;fontStyle=1;fontColor=#1A3A6B;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="550" y="65" width="480" height="480" as="geometry"/>
                </mxCell>
                <mxCell id="n301" value="&lt;b&gt;Supabase (Managed PostgreSQL)&lt;/b&gt;&#10;• Pro / Team Plan&#10;• Pooler Port 6543 (PgBouncer)&#10;• Backup: 自動日次バックアップ・PITR対応&#10;• DB: postgres&#10;• SPATIAL INDEX (PostGIS POINT型)&#10;&#10;&lt;b&gt;ElastiCache Redis 7 (Cluster)&lt;/b&gt;&#10;• cache.r6g.small × 2 (Multi-AZ)&#10;• 用途: セッション / キュー / キャッシュ / WS pub-sub&#10;• TLS + AUTH token 必須&#10;&#10;&lt;b&gt;S3 バケット&lt;/b&gt;&#10;• asahi-frontend: SPA assets (CloudFront origin)&#10;• asahi-storage: 配達員写真 / PDF / export&#10;• バージョニング: ON&#10;• ライフサイクル: 90日 → Glacier&#10;&#10;&lt;b&gt;Secrets Manager&lt;/b&gt;&#10;• /asahi/prod/app-key&#10;• /asahi/prod/db-password&#10;• /asahi/prod/pusher-secret&#10;• ECS TaskRole で自動ローテーション" style="text;html=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="565" y="90" width="450" height="440" as="geometry"/>
                </mxCell>
                <mxCell id="n400" value="ネットワーク・セキュリティ" style="rounded=1;whiteSpace=wrap;fillColor=#FCE8F3;strokeColor=#D5739D;fontSize=13;fontStyle=1;fontColor=#6B1E3A;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="65" width="550" height="480" as="geometry"/>
                </mxCell>
                <mxCell id="n401" value="&lt;b&gt;VPC / Subnet 設計&lt;/b&gt;&#10;• 10.0.0.0/16 (VPC)&#10;• Public  3a: 10.0.1.0/24  IGW + NAT&#10;• Public  3c: 10.0.2.0/24  IGW + NAT&#10;• App     3a: 10.0.11.0/24 ECS tasks&#10;• App     3c: 10.0.12.0/24 ECS replica&#10;• DB      3a: 10.0.21.0/24 Aurora Primary&#10;• DB      3c: 10.0.22.0/24 Aurora Replica + Redis&#10;&#10;&lt;b&gt;Security Group 設計&lt;/b&gt;&#10;• ALB-SG:  INBOUND 443 from 0.0.0.0/0&#10;• ECS-SG:  INBOUND 80/6001 from ALB-SG only&#10;• DB-SG:   INBOUND 3306 from ECS-SG only&#10;• Redis-SG: INBOUND 6379 from ECS-SG only&#10;&#10;&lt;b&gt;WAF ルール (AWS Managed)&lt;/b&gt;&#10;• AWSManagedRulesCommonRuleSet&#10;• AWSManagedRulesSQLiRuleSet&#10;• Rate limit: 1000 req/5min per IP&#10;&#10;&lt;b&gt;IAM TaskRole&lt;/b&gt;&#10;• ECS Task: S3 read/write (asahi-storage)&#10;• ECS Task: Secrets Manager read&#10;• ECS Task: CloudWatch Logs write" style="text;html=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1075" y="90" width="520" height="440" as="geometry"/>
                </mxCell>
                <mxCell id="n500" value="コスト概算 (月額 / 大阪リージョン ap-northeast-3)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;fontColor=#1A4A1A;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="40" y="575" width="480" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="n501" value="サービス              概算/月&#10;─────────────────────────────&#10;ECS Fargate (4 services) ≈  $80&#10;Supabase DB (Pro/Team) ≈ $25-$599&#10;ElastiCache Redis (r6g.small×2) ≈ $60&#10;ALB                    ≈  $20&#10;CloudFront + S3        ≈  $15&#10;NAT Gateway (2×)       ≈  $70&#10;Route 53               ≈   $1&#10;WAF                    ≈  $10&#10;Secrets Manager        ≈   $5&#10;CloudWatch Logs        ≈  $10&#10;ECR                    ≈   $3&#10;─────────────────────────────&#10;合計 (Small Scale)     ≈ $299/月 + DB&#10;&#10;※ トラフィック増加時は主にFargate + Supabase Computeが増加" style="text;html=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;fontSize=10;fontFamily=Courier New;" parent="1" vertex="1">
                    <mxGeometry x="55" y="600" width="450" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="n600" value="スケーリング方針" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;fontColor=#1A3A6B;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="550" y="575" width="480" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="n601" value="&lt;b&gt;ECS Auto Scaling&lt;/b&gt;&#10;• asahi-api: CPU &gt; 60% → +1 task (max 4)&#10;• asahi-worker: Queue depth &gt; 10 → +1&#10;• スケールイン: 15分間 CPU &lt; 30%&#10;&#10;&lt;b&gt;Supabase DB Scaling&lt;/b&gt;&#10;• Connection Pooler でコネクション溢れ防止&#10;• CPU / RAM 高時 → Compute Size変更 (ダッシュボードから無停止スケール)&#10;&#10;&lt;b&gt;新聞社ピーク時間対策&lt;/b&gt;&#10;• 朝刊: 3:00-6:00 JST (最大負荷)&#10;• Scheduled Scaling: 2:30 JST に事前スケールアウト&#10;• EventBridge → Lambda → ECS UpdateService&#10;&#10;&lt;b&gt;CDN キャッシュ戦略&lt;/b&gt;&#10;• SPA assets: CloudFront (1年キャッシュ)&#10;• API /delivery/*: No-Cache (動的)&#10;• OSM tiles: Service Worker CacheFirst" style="text;html=1;align=left;verticalAlign=top;spacingTop=10;spacingLeft=10;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="565" y="600" width="450" height="240" as="geometry"/>
                </mxCell>
                <mxCell id="n700" value="リアルタイム イベント一覧" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#AE4132;fontSize=13;fontStyle=1;fontColor=#6B1500;verticalAlign=top;spacingTop=8;" parent="1" vertex="1">
                    <mxGeometry x="1060" y="575" width="550" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="n701" value="チャンネル: private-shop.{shopId}&#10;&#10;イベント               配信元 → 受信者&#10;──────────────────────────────────&#10;DeliveryStarted        Worker → Admin&#10;DeliveryPointLogged    Worker → Admin&#10;DeliveryCompleted      Worker → Admin&#10;DelivererStatusChanged Worker → Admin&#10;LocationUpdated        Worker → Admin (5秒間隔)&#10;SosAlertCreated        Worker → Admin (緊急)&#10;&#10;WebSocket接続:&#10;• Soketi (Pusher-compat) :6001/ws&#10;• ALB → Soketi (WS Upgrade)&#10;• Laravel Echo → Pusher-js クライアント&#10;• Auth: /broadcasting/auth (Sanctum)" style="text;html=1;align=left;verticalAlign=top;spacingTop=8;spacingLeft=10;fontSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1075" y="600" width="520" height="240" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
