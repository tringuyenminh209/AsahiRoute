    <diagram id="p2-notes" name="セットアップ・注意点">
        <mxGraphModel dx="870" dy="784" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2339" pageHeight="1654" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="n100" value="超節約プラン — セットアップ手順 · 制限事項 · チューニング · スケールアップ方針" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#232F3E;" parent="1" vertex="1">
                    <mxGeometry x="40" y="20" width="2260" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="n200" value="🚀  初期セットアップ手順" style="rounded=1;fillColor=#EFF6FF;strokeColor=#2E73B8;fontSize=14;fontStyle=1;fontColor=#1A3A6B;verticalAlign=top;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="30" y="75" width="547" height="880" as="geometry"/>
                </mxCell>
                <mxCell id="n201" value="① EC2 起動 (ap-northeast-3a / Osaka)&#10;   AMI    : Amazon Linux 2023  ARM64&#10;   Instance: t4g.micro&#10;   Storage : EBS gp3  20 GB&#10;   Security Group:&#10;     TCP 22   ← 自分の IP のみ (SSH)&#10;     TCP 80/443  ← 0.0.0.0/0&#10;     TCP 6001    ← 0.0.0.0/0 (WebSocket)&#10;     ※ MySQL:3306 / Redis:6379 は SG で閉じる&#10;&#10;② Docker + Docker Compose v2 インストール&#10;   sudo dnf update -y&#10;   sudo dnf install docker git -y&#10;   sudo systemctl enable --now docker&#10;   sudo usermod -aG docker ec2-user&#10;   # Docker Compose v2&#10;   ARCH=linux-aarch64&#10;   BASE=https://github.com/docker/compose/&#10;        releases/latest/download&#10;   sudo mkdir -p /usr/local/lib/docker/cli-plugins&#10;   sudo curl -sSL $BASE/docker-compose-$ARCH \&#10;     -o /usr/local/lib/docker/cli-plugins/docker-compose&#10;   sudo chmod +x \&#10;     /usr/local/lib/docker/cli-plugins/docker-compose&#10;&#10;③ アプリデプロイ&#10;   git clone &lt;repo&gt; /opt/asahi &amp;&amp; cd /opt/asahi&#10;   cp src/.env.example src/.env&#10;   # .env に DB_PASSWORD・APP_KEY・OPTIMIZER_URL 等を設定&#10;   docker compose up -d&#10;   docker compose exec app php artisan key:generate&#10;   docker compose exec app php artisan migrate --seed&#10;&#10;④ Elastic IP 割り当て&#10;   AWS Console → EC2 → Elastic IPs&#10;   → Allocate new address → Associate (EC2)&#10;&#10;⑤ Route 53 レコード追加&#10;   A  api.yourdomain.jp → EC2 Elastic IP&#10;   A  ws.yourdomain.jp  → EC2 Elastic IP&#10;&#10;⑥ Let's Encrypt (Certbot) — API + WS SSL&#10;   sudo dnf install certbot -y&#10;   sudo certbot certonly --standalone \&#10;     -d api.yourdomain.jp \&#10;     -d ws.yourdomain.jp \&#10;     --email you@example.com --agree-tos&#10;   # Nginx で /etc/letsencrypt/live/... を参照&#10;   # 自動更新 cron (90日ごと):&#10;   0 3 * * * certbot renew --quiet \&#10;     --deploy-hook &quot;docker compose \&#10;     -f /opt/asahi/docker-compose.yml \&#10;     exec -T nginx nginx -s reload&quot;&#10;&#10;⑦ CloudFront + S3 (SPA フロントエンド)&#10;   aws s3 mb s3://asahi-frontend-bucket&#10;   aws s3 sync frontend/dist/ \&#10;     s3://asahi-frontend-bucket&#10;   # CloudFront ディストリビューション作成:&#10;   # Origin: asahi-frontend-bucket&#10;   #         .s3.amazonaws.com&#10;   # Viewer Protocol: Redirect HTTP→HTTPS&#10;   # ACM 証明書: us-east-1 で発行" style="text;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;strokeColor=none;fillColor=none;spacingLeft=12;spacingTop=10;overflow=fill;" parent="1" vertex="1">
                    <mxGeometry x="40" y="110" width="527" height="830" as="geometry"/>
                </mxCell>
                <mxCell id="n300" value="⚠  制限事項 vs 本番プラン (ECS Fargate)" style="rounded=1;fillColor=#FEF2F2;strokeColor=#DC2626;fontSize=14;fontStyle=1;fontColor=#7F1D1D;verticalAlign=top;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="607" y="75" width="547" height="880" as="geometry"/>
                </mxCell>
                <mxCell id="n301" value="項目            超節約プラン       本番プラン&#10;────────────────────────────────────────────&#10;可用性          99.0%〜            99.95%+&#10;                EC2 再起動で停止   Multi-AZ ALB+ECS&#10;&#10;スケール        手動 (停止→変更)   Auto Scaling&#10;&#10;DB バックアップ 日次 mysqldump     RDS 自動+PITR&#10;                リストア: 手動     リストア: Console&#10;&#10;SSL             Let's Encrypt      ACM 自動更新&#10;                90日更新 (cron)    (更新不要)&#10;&#10;WebSocket       Nginx proxy_pass   ALB WS Target&#10;                設定が必要&#10;&#10;セキュリティ    Security Group     WAF+Shield+ALB&#10;                EC2 直接公開&#10;&#10;デプロイ        SSH + git pull     ECS Rolling&#10;                数秒〜分のダウン   Zero-downtime&#10;&#10;監視            CloudWatch 基本    CW + Sentry&#10;                EC2 Status Check   + SNS アラーム&#10;&#10;RAM             1 GB (チューニング)  無制限 (Fargate)&#10;                ギリギリ ≈ 980 MB&#10;&#10;同時接続        〜30 req/s         〜500+ req/s&#10;&#10;コスト          ≈ $12/月           ≈ $394/月&#10;────────────────────────────────────────────&#10;&#10;✅ 推奨ユースケース:&#10;   配達員 1〜5 名 / 購読者 〜200 件&#10;   MVP 段階 / コスト最優先&#10;   ダウンタイム許容あり&#10;&#10;⚠ 移行検討のトリガー:&#10;   購読者 200 超 / ダウンタイム許容不可&#10;   → 本番プラン (~$394/月)&#10;   または中間コース検討" style="text;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;strokeColor=none;fillColor=none;spacingLeft=12;spacingTop=10;overflow=fill;" parent="1" vertex="1">
                    <mxGeometry x="617" y="110" width="527" height="830" as="geometry"/>
                </mxCell>
                <mxCell id="n400" value="⚙  PHP-FPM · MySQL · Redis チューニング (1 GB RAM)" style="rounded=1;fillColor=#FCE8F3;strokeColor=#E7157B;fontSize=14;fontStyle=1;fontColor=#6B1E3A;verticalAlign=top;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1184" y="75" width="547" height="880" as="geometry"/>
                </mxCell>
                <mxCell id="n401" value="# docker/php/php.ini&#10;memory_limit              = 128M&#10;upload_max_filesize       = 10M&#10;post_max_size             = 10M&#10;opcache.enable            = 1&#10;opcache.memory_consumption = 64&#10;opcache.max_accelerated_files = 4000&#10;opcache.revalidate_freq   = 0&#10;&#10;# docker/php/www.conf  (PHP-FPM pool)&#10;pm                        = dynamic&#10;pm.max_children           = 5&#10;pm.start_servers          = 2&#10;pm.min_spare_servers      = 1&#10;pm.max_spare_servers      = 3&#10;pm.max_requests           = 500&#10;request_terminate_timeout = 120&#10;# worker: max_children=2 に削減推奨&#10;&#10;# docker/mysql/my.cnf&#10;[mysqld]&#10;innodb_buffer_pool_size   = 128M&#10;innodb_log_file_size      = 32M&#10;max_connections           = 50&#10;query_cache_type          = 0&#10;tmp_table_size            = 16M&#10;max_heap_table_size       = 16M&#10;innodb_flush_method       = O_DIRECT&#10;innodb_flush_log_at_trx_commit = 2&#10;&#10;# docker-compose.yml (Redis)&#10;redis:&#10;  command: redis-server&#10;    --maxmemory 64mb&#10;    --maxmemory-policy allkeys-lru&#10;    --save &quot;&quot;&#10;&#10;# RAM 使用量概算 (1 GB EC2)&#10;OS + Docker      : 〜300 MB&#10;PHP-FPM (×5)     : 〜250 MB  ← app&#10;PHP-FPM (×2)     :  〜80 MB  ← worker&#10;MySQL            : 〜200 MB&#10;Soketi           :  〜80 MB&#10;Optimizer        :  〜80 MB&#10;Redis            :  〜70 MB&#10;────────────────────────────&#10;合計              : 〜1,060 MB&#10;&#10;⚠ 超過注意&#10;→ 対策: app max_children=4,&#10;  worker=2 に下げる&#10;  または swap 1 GB 追加 (EBS コスト小)&#10;  sudo dd if=/dev/zero of=/swapfile \&#10;    bs=128M count=8&#10;  sudo chmod 600 /swapfile&#10;  sudo mkswap /swapfile&#10;  sudo swapon /swapfile&#10;  echo '/swapfile swap swap \&#10;    defaults 0 0' | \&#10;    sudo tee -a /etc/fstab" style="text;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;strokeColor=none;fillColor=none;spacingLeft=12;spacingTop=10;overflow=fill;" parent="1" vertex="1">
                    <mxGeometry x="1194" y="110" width="527" height="830" as="geometry"/>
                </mxCell>
                <mxCell id="n500" value="📈  スケールアップ · バックアップ · SSH デプロイ" style="rounded=1;fillColor=#FFF8EE;strokeColor=#D6B656;fontSize=14;fontStyle=1;fontColor=#6B4400;verticalAlign=top;spacingTop=10;" parent="1" vertex="1">
                    <mxGeometry x="1761" y="75" width="547" height="880" as="geometry"/>
                </mxCell>
                <mxCell id="n501" value="── スケールアップトリガー ──&#10;CPU 常時 &gt; 70%&#10;  → t4g.small ($15/月)&#10;RAM 常時 &gt; 80%&#10;  → t4g.small (2 GB)&#10;ダウン許容不可&#10;  → RDS + Multi-AZ + ALB&#10;配達員 &gt; 10 名&#10;  → t4g.medium 検討&#10;購読者 &gt; 500&#10;  → 本番プラン移行&#10;&#10;💡 中間コース (~$28/月)&#10;   t4g.small + RDS db.t4g.micro&#10;   = EC2 $15 + RDS $13 = $28/月&#10;&#10;── バックアップ (/etc/cron.d/asahi) ──&#10;0 17 * * * root \&#10;  docker exec asahi-mysql \&#10;    mysqldump -u root \&#10;    -p&quot;$MYSQL_ROOT_PASSWORD&quot; \&#10;    asahi_route \&#10;  | gzip \&#10;  | aws s3 cp - \&#10;    s3://asahi-bucket/backup/&#10;    $(date +\%Y\%m\%d).sql.gz&#10;&#10;# リストア手順&#10;aws s3 cp \&#10;  s3://asahi-bucket/backup/&#10;  YYYYMMDD.sql.gz - \&#10;  | gunzip \&#10;  | docker exec -i asahi-mysql \&#10;    mysql -u root \&#10;    -p&quot;$PASS&quot; asahi_route&#10;&#10;── SSH デプロイ (GitHub Actions) ──&#10;# .github/workflows/deploy-budget.yml&#10;deploy:&#10;  steps:&#10;    - uses: actions/checkout@v4&#10;    - name: Build frontend&#10;      run: |&#10;        cd frontend&#10;        npm ci &amp;&amp; npm run build&#10;    - name: Sync S3&#10;      run: |&#10;        aws s3 sync frontend/dist/ \&#10;          s3://$S3_BUCKET --delete \&#10;          --cache-control \&#10;          &quot;max-age=31536000,immutable&quot;&#10;        aws s3 cp \&#10;          frontend/dist/index.html \&#10;          s3://$S3_BUCKET/index.html \&#10;          --cache-control &quot;no-cache&quot;&#10;        aws cloudfront \&#10;          create-invalidation \&#10;          --distribution-id $CF_ID \&#10;          --paths '/*'&#10;    - name: Deploy to EC2&#10;      uses: appleboy/ssh-action@v1&#10;      with:&#10;        host: ${{ secrets.EC2_HOST }}&#10;        username: ec2-user&#10;        key: ${{ secrets.EC2_SSH_KEY }}&#10;        script: |&#10;          cd /opt/asahi&#10;          git pull origin main&#10;          docker compose build \&#10;            app worker&#10;          docker compose up -d \&#10;            --no-deps app worker \&#10;            optimizer&#10;          docker compose exec -T \&#10;            app php artisan \&#10;            migrate --force&#10;          docker compose exec -T \&#10;            app php artisan \&#10;            config:cache&#10;          docker compose exec -T \&#10;            app php artisan \&#10;            route:cache" style="text;align=left;verticalAlign=top;fontSize=10;fontFamily=Courier New;strokeColor=none;fillColor=none;spacingLeft=12;spacingTop=10;overflow=fill;" parent="1" vertex="1">
                    <mxGeometry x="1771" y="110" width="527" height="830" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>