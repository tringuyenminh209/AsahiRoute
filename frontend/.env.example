# ── API ───────────────────────────────────────────────────────────────────────
# Dev:  leave empty → Vite proxy rewrites /api → http://localhost:2009
# Prod: set full URL → VITE_API_URL=https://api.yourdomain.jp/api/v1
VITE_API_URL=

# ── WebSocket (Pusher/Soketi) ─────────────────────────────────────────────────
# Dev:  VITE_PUSHER_SCHEME=http,  VITE_PUSHER_HOST=localhost, VITE_PUSHER_PORT=6001
# Prod: VITE_PUSHER_SCHEME=https, VITE_PUSHER_HOST=ws.yourdomain.jp, VITE_PUSHER_PORT=443
VITE_PUSHER_APP_KEY=asahi-key
VITE_PUSHER_HOST=localhost
VITE_PUSHER_PORT=6001
VITE_PUSHER_SCHEME=http
VITE_PUSHER_APP_CLUSTER=mt1
